# GridOS reduced launch configuration
# Copy this file to .env for local development.

GRIDOS_ENV=development
GRIDOS_LOG_LEVEL=INFO
GRIDOS_SECRET_KEY=change-me-before-public-deployment

GRIDOS_HOST=0.0.0.0
GRIDOS_PORT=8000
GRIDOS_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Default launch path: in-memory storage with no external database required.
GRIDOS_USE_INMEMORY_STORAGE=true

# Only used when GRIDOS_USE_INMEMORY_STORAGE=false.
GRIDOS_STORAGE_BACKEND=influxdb

# Optional InfluxDB configuration.
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=replace-with-real-token
INFLUXDB_ORG=gridos
INFLUXDB_BUCKET=telemetry

# Optional TimescaleDB configuration.
TIMESCALEDB_DSN=postgresql://gridos:gridos@localhost:5432/gridos
