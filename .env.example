# GridOS Environment Configuration
# Copy this file to .env and fill in the values.

# ── General ──────────────────────────────────────────────
GRIDOS_ENV=development
GRIDOS_LOG_LEVEL=INFO
GRIDOS_SECRET_KEY=change-me-to-a-random-string

# ── FastAPI ──────────────────────────────────────────────
GRIDOS_HOST=0.0.0.0
GRIDOS_PORT=8000
GRIDOS_CORS_ORIGINS=["http://localhost:3000"]

# ── InfluxDB ─────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=gridos
INFLUXDB_BUCKET=telemetry

# ── TimescaleDB ──────────────────────────────────────────
TIMESCALEDB_DSN=postgresql://gridos:gridos@localhost:5432/gridos

# ── MQTT Broker ──────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=gridos/

# ── Modbus ───────────────────────────────────────────────
MODBUS_DEFAULT_HOST=localhost
MODBUS_DEFAULT_PORT=502

# ── Storage Backend Selection ────────────────────────────
# Options: influxdb, timescaledb
GRIDOS_STORAGE_BACKEND=influxdb

# ── ML / Forecasting ────────────────────────────────────
ML_MODEL_DIR=./models_cache
ML_FORECAST_HORIZON_HOURS=24

# ── Optimization ─────────────────────────────────────────
OPT_TIME_HORIZON_HOURS=24
OPT_TIME_STEP_MINUTES=15
