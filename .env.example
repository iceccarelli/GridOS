# GridOS Environment Configuration
# Copy this file to .env before running the application.

# General runtime settings
GRIDOS_ENV=development
GRIDOS_LOG_LEVEL=INFO
GRIDOS_SECRET_KEY=replace-this-before-production

# API settings
GRIDOS_HOST=0.0.0.0
GRIDOS_PORT=8000
GRIDOS_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Default launch mode
# When true, GridOS keeps telemetry in memory and does not require an external database.
GRIDOS_USE_INMEMORY_STORAGE=true

# Optional persistent backend selection
# Only used when GRIDOS_USE_INMEMORY_STORAGE=false
GRIDOS_STORAGE_BACKEND=influxdb

# Optional InfluxDB settings
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=replace-with-real-token
INFLUXDB_ORG=gridos
INFLUXDB_BUCKET=telemetry

# Optional TimescaleDB settings
TIMESCALEDB_DSN=postgresql://gridos:gridos@localhost:5432/gridos
